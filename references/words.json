{
  "version": "2.0",
  "description": "中文敏感词清单 — 跨项目共享。修改此文件即可全局生效。",
  "dimensions": {
    "risk_type": {
      "description": "风险类型 — 该词触发的负面联想类别",
      "values": {
        "security": "安全/情报类 — espionage, surveillance, covert ops",
        "privacy": "隐私/数据类 — scraping, unauthorized collection, tracking",
        "legal": "法律/合规类 — theft, infringement, illegal access"
      }
    },
    "domain": {
      "description": "语义领域 — 该词所属的概念领域",
      "values": {
        "intelligence": "情报/军事",
        "surveillance": "监视/监控",
        "data_collection": "数据采集",
        "cyber": "网络安全"
      }
    },
    "severity": {
      "description": "严重程度 — 该词在审查中的敏感等级",
      "values": {
        "high": "高危 — 极易触发敏感审查，必须替换",
        "medium": "中等 — 视上下文可能引发联想",
        "low": "低风险 — 仅特定语境下敏感"
      }
    }
  },
  "rules": [
    {
      "word": "情报",
      "replacements": ["洞察", "信息", "数据"],
      "dimensions": {
        "risk_type": "security",
        "domain": "intelligence",
        "severity": "high"
      },
      "context": "general",
      "note": "espionage/intelligence 联想，在分析类语境用「洞察」，中性描述用「信息」，统计类用「数据」"
    },
    {
      "word": "监控",
      "replacements": ["监测", "跟踪", "观察"],
      "dimensions": {
        "risk_type": "security",
        "domain": "surveillance",
        "severity": "high"
      },
      "context": "general",
      "note": "surveillance 联想，技术语境用「监测」，进度类用「跟踪」，通用用「观察」"
    },
    {
      "word": "抓取",
      "replacements": ["采集", "提取", "获取"],
      "dimensions": {
        "risk_type": "privacy",
        "domain": "data_collection",
        "severity": "medium"
      },
      "context": "data",
      "note": "data scraping 联想，数据收集用「采集」，信息提取用「提取」"
    },
    {
      "word": "爬虫",
      "replacements": ["采集工具", "自动采集"],
      "dimensions": {
        "risk_type": "legal",
        "domain": "data_collection",
        "severity": "medium"
      },
      "context": "tech",
      "note": "web crawler 联想，用功能性描述替代"
    },
    {
      "word": "窃取",
      "replacements": ["提取", "读取"],
      "dimensions": {
        "risk_type": "legal",
        "domain": "cyber",
        "severity": "high"
      },
      "context": "general",
      "note": "theft 联想，用技术性中性词替代"
    }
  ]
}
